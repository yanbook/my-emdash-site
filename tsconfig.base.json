{
	"compilerOptions": {
		"target": "ES2022",
		"module": "preserve",
		"lib": ["ES2022"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"allowJs": false,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true
	}
}
