{
	"compilerOptions": {
		"target": "ES2022",
		"module": "preserve",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*"]
}
