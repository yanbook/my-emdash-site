{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": false,
		"types": ["astro/client"]
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"tests",
		"src/astro/**",
		"src/components/**",
		"src/preview/**",
		"src/ui.ts"
	]
}
