---
interface Props {
	placeholder?: string;
}

const { placeholder = "Search..." } = Astro.props;
---

<form method="get" action="/search" class="widget-search">
	<input
		type="search"
		name="q"
		placeholder={placeholder}
		aria-label="Search"
		class="widget-search__input"
	/>
	<button type="submit" class="widget-search__button">Search</button>
</form>
