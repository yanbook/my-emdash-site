{
	"compilerOptions": {
		"target": "ES2022",
		"module": "preserve",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"declaration": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"types": ["@cloudflare/workers-types", "astro/client"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"]
}
