{
	"id": "cdn-optimizer",
	"version": "1.0.0",
	"capabilities": ["network:fetch"],
	"allowedHosts": ["cdn-check.example.com"],
	"storage": {},
	"hooks": ["plugin:activate"],
	"routes": [],
	"admin": {
		"settingsSchema": {
			"cdnEndpoint": { "type": "string", "label": "CDN Endpoint URL" },
			"accessKeyId": { "type": "secret", "label": "CDN Access Key" },
			"secretAccessKey": { "type": "secret", "label": "CDN Secret Key" },
			"bucketRegion": {
				"type": "select",
				"label": "Region",
				"options": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"]
			}
		}
	}
}
